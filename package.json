{
  "name": "x4-dashboard",
  "version": "1.4.0",
  "description": "X4: Foundations server launcher and cockpit dashboard",
  "main": "launcher/main.cjs",
  "author": "Filip Piechowski",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fpiechowski/x4-dashboard.git"
  },
  "homepage": "https://github.com/fpiechowski/x4-dashboard#readme",
  "bugs": {
    "url": "https://github.com/fpiechowski/x4-dashboard/issues"
  },
  "keywords": [
    "x4-foundations",
    "dashboard",
    "react",
    "nodejs",
    "arwes"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "install:all": "npm --prefix server install && npm --prefix client install && npm --prefix landing install",
    "dev": "electron .",
    "dev:mock": "cross-env MOCK=true electron .",

    "build": "npm --prefix client run build",
    "build:landing": "npm --prefix landing run build",
    "start": "electron .",
    "serve": "node server/index.js",
    "typecheck": "npm --prefix client run typecheck",
    "typecheck:landing": "npm --prefix landing run typecheck",
    "check": "npm run typecheck",
    "test": "npm --prefix server test",
    "test:watch": "npm --prefix server run test:watch",
    "test:coverage": "npm --prefix server run test:coverage",
    "release:check": "npm run typecheck && npm run build",
    "release:bundle": "npm run release:check && node scripts/create-server-bundle.js && node scripts/create-lua-mod-bundle.js",
    "desktop:dist": "npm run release:check && electron-builder --publish never"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.fpiechowski.x4dashboard",
    "productName": "X4 Dashboard Server",
    "compression": "maximum",
    "directories": {
      "output": "release"
    },
    "icon": "launcher/assets/icon.ico",
    "files": [
      "launcher/**/*",
      "package.json",
      "LICENSE",
      "README.md"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*",
          "!public/**"
        ]
      },
      {
        "from": "server/node_modules",
        "to": "server/node_modules",
        "filter": [
          "**/*",
          "!x4-dashboard"
        ]
      },
      {
        "from": "server/public",
        "to": "server/public"
      },
      {
        "from": "SECURITY.md",
        "to": "SECURITY.md"
      }
    ],
    "asarUnpack": [
      "launcher/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "icon": "launcher/assets/icon.ico",
      "target": [
        "portable",
        "nsis"
      ]
    },
    "portable": {
      "artifactName": "x4-dashboard-server-launcher-${version}-portable.${ext}"
    },
    "nsis": {
      "artifactName": "x4-dashboard-server-launcher-${version}-setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "differentialPackage": false,
      "installerHeader": "launcher/assets/installer-header.bmp",
      "installerSidebar": "launcher/assets/installer-sidebar.bmp",
      "uninstallerSidebar": "launcher/assets/installer-sidebar.bmp",
      "installerHeaderIcon": "launcher/assets/icon.ico"
    }
  }
}

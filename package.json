{
  "name": "x4-dashboard",
  "version": "1.1.1",
  "description": "X4: Foundations server launcher and cockpit dashboard",
  "main": "electron/main.cjs",
  "author": "Filip Piechowski",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fpiechowski/x4-dashboard.git"
  },
  "homepage": "https://github.com/fpiechowski/x4-dashboard#readme",
  "bugs": {
    "url": "https://github.com/fpiechowski/x4-dashboard/issues"
  },
  "keywords": [
    "x4-foundations",
    "dashboard",
    "react",
    "nodejs",
    "arwes"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "install:all": "npm --prefix server install && npm --prefix client install",

    "dev": "concurrently -n server,client -c cyan,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "desktop:dev": "concurrently -n server,client,electron -c cyan,magenta,yellow \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:electron\"",
    "dev:electron": "cross-env ELECTRON_RENDERER_URL=http://localhost:3000 electron .",

    "mock": "node server/index.js --mock",
    "dev:mock": "concurrently -n server,client -c cyan,magenta \"node server/index.js --mock\" \"npm run dev:client\"",

    "build": "npm --prefix client run build",
    "start": "node server/index.js",
    "desktop:start": "electron .",
    "typecheck": "npm --prefix client run typecheck",
    "check": "npm run typecheck",
    "release:check": "npm run typecheck && npm run build",
    "dist:server-bundle": "node scripts/create-server-bundle.js",
    "dist:lua-mod": "node scripts/create-lua-mod-bundle.js",
    "release:bundle": "npm run release:check && npm run dist:server-bundle && npm run dist:lua-mod",
    "desktop:dist": "npm run release:check && electron-builder --publish never"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.fpiechowski.x4dashboard",
    "productName": "X4 Dashboard Server",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "LICENSE",
      "README.md"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*",
          "!public/**"
        ]
      },
      {
        "from": "server/node_modules",
        "to": "server/node_modules"
      },
      {
        "from": "server/public",
        "to": "server/public"
      },
      {
        "from": "SECURITY.md",
        "to": "SECURITY.md"
      }
    ],
    "asarUnpack": [
      "electron/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable",
        "nsis"
      ]
    },
    "portable": {
      "artifactName": "x4-dashboard-server-launcher-${version}-portable.${ext}"
    },
    "nsis": {
      "artifactName": "x4-dashboard-server-launcher-${version}-setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}

{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5-nano",
  "share": "manual",
  "instructions": [
    "AGENTS.md"
  ],
  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      ".npm-cache/**",
      "dist/**",
      "release/**",
      "server/public/**"
    ]
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git add*": "allow",
      "git commit*": "allow",
      "gh *": "allow",
      "gh release view*": "allow",
      "gh release list*": "allow",
      "gh release create*": "ask",
      "gh release edit*": "ask",
      "gh release delete*": "deny",
      "git push*": "ask",
      "git push --force*": "deny",
      "git tag*": "ask",
      "git reset --hard*": "deny",
      "git checkout --*": "deny",
      "git clean*": "ask",
      "git rebase -i*": "deny",
      "git commit --amend*": "ask"
    }
  },
  "agent": {
    "build": {
      "model": "openai/gpt-5.4",
      "temperature": 0.1,
      "permission": {
        "bash": {
          "*": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git branch*": "allow",
          "git add*": "allow",
          "git commit*": "allow",
          "gh *": "allow",
          "gh release view*": "allow",
          "gh release list*": "allow",
          "gh release create*": "ask",
          "gh release edit*": "ask",
          "gh release delete*": "deny",
          "git push*": "ask",
          "git push --force*": "deny",
          "git tag*": "ask",
          "git reset --hard*": "deny",
          "git checkout --*": "deny",
          "git clean*": "ask",
          "git rebase -i*": "deny",
          "git commit --amend*": "ask"
        }
      }
    },
    "plan": {
      "model": "openai/gpt-5.4",
      "temperature": 0.1,
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    }
  }
}

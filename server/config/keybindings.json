{
  "description": "Key bindings for X4 Dashboard system toggle buttons",
  "note": "Key format uses Windows SendKeys notation: '{F1}'-'{F12}' for function keys, 'a'-'z' for letters, '^a' = Ctrl+A, '+a' = Shift+A, '%a' = Alt+A, '{ENTER}', '{ESC}', '{SPACE}', '{UP}', '{DOWN}', '{LEFT}', '{RIGHT}'",
  "bindings": {
    "flightAssist": {
      "key": "{SPACE}",
      "modifiers": [
        "ctrl"
      ],
      "label": "Flight Assist",
      "description": "Toggle flight assist on/off"
    },
    "seta": {
      "key": "+4",
      "modifiers": [],
      "label": "SETA",
      "description": "Toggle SETA (time acceleration)"
    },
    "autopilot": {
      "key": "+a",
      "modifiers": [],
      "label": "Autopilot",
      "description": "Toggle autopilot navigation"
    },
    "travelDrive": {
      "key": "+1",
      "modifiers": [],
      "label": "Travel Drive",
      "description": "Toggle travel drive"
    },
    "scanMode": {
      "key": "+2",
      "modifiers": [],
      "label": "Scan Mode",
      "description": "Toggle short-range scan mode"
    },
    "longRangeScan": {
      "key": "+3",
      "modifiers": [],
      "label": "Long-Range Scan",
      "description": "Toggle long-range scan mode"
    },
    "openMap": {
      "key": "m",
      "modifiers": [],
      "label": "Map",
      "description": "Open the in-game map"
    },
    "openMissionManager": {
      "key": "+m",
      "modifiers": [],
      "label": "Mission Manager",
      "description": "Open the mission manager using your configured in-game shortcut"
    }
  }
}